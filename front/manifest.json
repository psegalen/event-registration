{
  "name": "Event Registration",
  "short_name": "EvReg",
  "display": "standalone",
  "start_url": "/?isPwa=true",
  "background_color": "#000000",
  "theme_color": "#1BAEE7",
  "icons": [
    {
      "src": "src/assets/logo512.png",
      "type": "image/png",
      "sizes": "512x512"
    },
    {
      "src": "src/assets/logo192.png",
      "type": "image/png",
      "sizes": "192x192"
    }
  ],
  "shortcuts": [
    {
      "name": "Ouvrir en mode CSV",
      "url": "/?isCsv=true",
      "icons": [
        {
          "src": "src/assets/logo512.png",
          "type": "image/png",
          "sizes": "512x512"
        },
        {
          "src": "src/assets/logo192.png",
          "type": "image/png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "/?isCsv=true",
      "accept": {
        "text/csv": [".csv"]
      }
    }
  ]
}
